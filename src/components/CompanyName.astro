---
type Props = {
  company: string;
};

const { company } = Astro.props;
---

{
  company.startsWith("Seznam.cz") ? (
    <>
      <span style="color: #cc0000;">Seznam.cz</span>
      {company.replace("Seznam.cz", "")}
    </>
  ) : company.startsWith("Slovenská sporiteľňa") ? (
    <span style="color: #245375;">{company}</span>
  ) : (
    company
  )
}
