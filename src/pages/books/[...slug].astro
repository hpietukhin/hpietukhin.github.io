---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";

export async function getStaticPaths() {
  const books = (await getCollection("books"));
    return books.map((book) => ({
    params: { slug: book.id },
    props: book,
  }));
}
type Props = CollectionEntry<"books">;

const book = Astro.props;
const { Content } = await render(book);
---

<PageLayout title={book.data.title} description={book.data.description}>
  <Container>
    <div>
      <BackToPrev href="/books">
        Back to books
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={book.data.date} />
        </div>
        <span class="meta-separator" aria-hidden="true"></span>
        <div class="font-base text-sm">
          {readingTime(book.body ?? "")}
        </div>
      </div>
      <div class="text-2xl font-semibold theme-heading">
        {book.data.title}
      </div>
    </div>
    <article>
      <Content />
    </article>
  </Container>
</PageLayout>